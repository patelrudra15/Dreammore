{
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/about", "destination": "/about-us/about.html" },
    { "source": "/blog", "destination": "/blog/blog.html" },
    { "source": "/contact", "destination": "/contact-us/contact.html" },
    { "source": "/careers", "destination": "/careers/careers.html" },
    { "source": "/schemes", "destination": "/government-schemes/schemes.html" },
    { "source": "/loan", "destination": "/loan/loan.html" },
    { "source": "/service", "destination": "/service/service.html" },
    { "source": "/privacy", "destination": "/legal/privacy-policy.html" },
    { "source": "/refund", "destination": "/legal/refund-policy.html" },
    { "source": "/terms", "destination": "/legal/terms.html" }
  ],
  "routes": [
    { "src": "/public/(.*)", "dest": "/public/$1" }
  ]
}